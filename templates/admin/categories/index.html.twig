{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Catégories</h1>
        <a href="{{ path('app_admin_categorie_new') }}" class="btn btn-success">+ Nouvelle catégorie</a>
    </div>

    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for categorie in categories %}
                <tr>
                    <td>{{ categorie.id }}</td>
                    <td>{{ categorie.nom }}</td>
                    <td>
                        <a href="{{ path('app_admin_categorie_edit', {id: categorie.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                        <form method="post" action="{{ path('app_admin_categorie_delete', {id: categorie.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ?')">
                            <button class="btn btn-sm btn-danger">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="3" class="text-center">Aucune catégorie</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour</a>
{% endblock %}