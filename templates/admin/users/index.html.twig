{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Utilisateurs</h1>
        <a href="{{ path('app_admin_user_new') }}" class="btn btn-success">+ Nouvel utilisateur</a>
    </div>

    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Email</th>
                <th>Rôles</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>{{ user.email }}</td>
                    <td>{{ user.roles|join(', ') }}</td>
                    <td>
                        <a href="{{ path('app_admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-center">Aucun utilisateur</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour</a>
{% endblock %}