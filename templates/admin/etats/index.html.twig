{% extends 'base.html.twig' %}

{% block title %}États{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>États</h1>
        <a href="{{ path('app_admin_etat_new') }}" class="btn btn-success">+ Nouvel état</a>
    </div>

    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for etat in etats %}
                <tr>
                    <td>{{ etat.id }}</td>
                    <td>{{ etat.nom }}</td>
                    <td>
                        <a href="{{ path('app_admin_etat_edit', {id: etat.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                        <form method="post" action="{{ path('app_admin_etat_delete', {id: etat.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ?')">
                            <button class="btn btn-sm btn-danger">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="3" class="text-center">Aucun état</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour</a>
{% endblock %}