{% extends 'base.html.twig' %}

{% block title %}Liste des tickets — Staff{% endblock %}

{% block body %}
    <h1>Liste des tickets</h1>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Auteur</th>
                <th>Catégorie</th>
                <th>État</th>
                <th>Responsable</th>
                <th>Date d'ouverture</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for ticket in tickets %}
                <tr>
                    <td>{{ ticket.id }}</td>
                    <td>{{ ticket.auteur }}</td>
                    <td>{{ ticket.categorie.nom }}</td>
                    <td>
                        <span class="badge bg-primary">{{ ticket.etat.nom }}</span>
                    </td>
                    <td>{{ ticket.responsable ? ticket.responsable.email : '-' }}</td>
                    <td>{{ ticket.dateOuverture ? ticket.dateOuverture|date('d/m/Y') : '-' }}</td>
                    <td>
                        <a href="{{ path('app_staff_ticket_show', {id: ticket.id}) }}" class="btn btn-sm btn-info">Voir</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center">Aucun ticket</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}